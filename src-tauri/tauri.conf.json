{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSHelter",
  "version": "0.1.8",
  "identifier": "com.sshelter.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SSHelter",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0d0d0d",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' tauri: data: https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost https://github.com https://objects.githubusercontent.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2NDZFQUJDMzIyNDAwODcKUldTSEFDUXl2T3BHSnQveWNJR2ZUTld3dmswcGZ0dHoyc2svWnJGemIzOVh5VjJ4SWNSVmVXcGIK",
      "endpoints": [
        "https://github.com/adenijiayocharles/sshelter/releases/latest/download/latest.json"
      ]
    }
  }
}
